        {
          "name": "Chat (teste direto)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Oi, voces tem tenis branco?\",\n  \"conversation\": {\n    \"id\": 1001\n  },\n  \"contact\": {\n    \"id\": 2001\n  }\n}"
            },
            "url": "{{base_url}}/auto-reply/chat"
          }
        },
        {
          "name": "Webhook (simulado)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Chatwoot-Signature",
                "value": "{{chatwoot_signature}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"message_created\",\n  \"id\": \"delivery-1\",\n  \"content\": \"Tenho duvida sobre frete\",\n  \"private\": false\n}"
            },
            "url": "{{base_url}}/auto-reply/webhook"
          }
        }
