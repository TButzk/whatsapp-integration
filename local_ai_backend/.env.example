APP_NAME=local-ai-backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8010
AUTO_REPLY_ENABLED=true
LOG_LEVEL=INFO
RAG_ENABLED=true
REDIS_URL=redis://localhost:6379/0
QUEUE_NAME=incoming_messages
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/local_ai_backend

OLLAMA_BASE_URL=http://localhost:11435
OLLAMA_MODEL_FAST=qwen3:8b-q4_K_M
OLLAMA_MODEL_SMART=qwen3:14b
LLM_TIMEOUT_SECONDS=45
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.1

CHATWOOT_WEBHOOK_SECRET=
WHATSAPP_WEBHOOK_SECRET=

# Shopify Customer Account MCP (private customer/order lookup)
SHOPIFY_CUSTOMER_LOOKUP_ENABLED=false
SHOPIFY_CUSTOMER_MCP_ENDPOINT=
SHOPIFY_CUSTOMER_MCP_TOKEN=
SHOPIFY_CUSTOMER_TIMEOUT_SECONDS=20
# Legacy-compatible timeout key (optional). If set, it overrides SHOPIFY_CUSTOMER_TIMEOUT_SECONDS.
SHOPIFY_CUSTOMER_MCP_TIMEOUT=

# Optional OAuth refresh fallback (NOT required when SHOPIFY_CUSTOMER_MCP_TOKEN is set)
SHOPIFY_CUSTOMER_OAUTH_TOKEN_ENDPOINT=
SHOPIFY_CUSTOMER_OAUTH_AUTHORIZATION_ENDPOINT=
SHOPIFY_CUSTOMER_REDIRECT_URI=
SHOPIFY_CUSTOMER_OAUTH_USE_PKCE=true
SHOPIFY_CUSTOMER_CLIENT_ID=
SHOPIFY_CUSTOMER_CLIENT_SECRET=
SHOPIFY_CUSTOMER_REFRESH_TOKEN=
SHOPIFY_CUSTOMER_SCOPES=openid email customer-account-api:full customer-account-mcp-api:full