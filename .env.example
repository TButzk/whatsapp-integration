# =============================================================================
# .env.example — Variáveis de ambiente para o Chatwoot Community Edition
#
# Instruções:
#   1. Copie este arquivo:  cp .env.example .env
#   2. Substitua TODOS os valores marcados com <...> por valores reais.
#   3. Nunca versione o arquivo .env com segredos reais.
# =============================================================================

# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------

# URL pública da instância (sem barra no final).
# Deve corresponder ao domínio configurado no Cloudflare Tunnel.
FRONTEND_URL=https://<seu-dominio.example.com>

# Chave secreta do Rails — gere com:  openssl rand -hex 64
SECRET_KEY_BASE=<chave_secreta_de_64_bytes_em_hex>

# -----------------------------------------------------------------------------
# Banco de Dados (PostgreSQL 14+)
# -----------------------------------------------------------------------------

POSTGRES_PASSWORD=<senha_forte_do_postgres>

# String de conexão usada pelo Rails.
# Host = nome do serviço Docker definido no docker-compose.yaml.
# Substitua <senha_forte_do_postgres> pela mesma senha definida em POSTGRES_PASSWORD.
DATABASE_URL=postgresql://chatwoot:<senha_forte_do_postgres>@postgres:5432/chatwoot_production

# -----------------------------------------------------------------------------
# Cache e Filas (Redis 7+)
# -----------------------------------------------------------------------------

REDIS_PASSWORD=<senha_forte_do_redis>

# String de conexão usada pelo Rails / Sidekiq.
# Substitua <senha_forte_do_redis> pela mesma senha definida em REDIS_PASSWORD.
REDIS_URL=redis://:<senha_forte_do_redis>@redis:6379/0

# -----------------------------------------------------------------------------
# SMTP — envio de e-mails transacionais do sistema
# (confirmação de conta, redefinição de senha, notificações, etc.)
# -----------------------------------------------------------------------------

SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=<usuario_smtp>
SMTP_PASSWORD=<senha_smtp>
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true
SMTP_OPENSSL_VERIFY_MODE=peer

# Remetente padrão dos e-mails enviados pelo Chatwoot.
MAILER_SENDER_EMAIL=Chatwoot <noreply@<seu-dominio.example.com>>

# -----------------------------------------------------------------------------
# Cloudflare Tunnel
# -----------------------------------------------------------------------------

# Token gerado ao criar o túnel no painel da Cloudflare:
#   https://one.dash.cloudflare.com/ → Networks → Tunnels → Create a tunnel
CLOUDFLARE_TUNNEL_TOKEN=<token_do_cloudflare_tunnel>

# -----------------------------------------------------------------------------
# Configurações opcionais do Chatwoot
# -----------------------------------------------------------------------------

# Habilita o registro de novos usuários pelo frontend (true/false).
ENABLE_ACCOUNT_SIGNUP=false

# Nível de log da aplicação Rails (debug, info, warn, error).
LOG_LEVEL=info

# Tamanho máximo do log (em MB) antes de rotacionar.
LOG_SIZE=500
