CHATWOOT_BASE_URL=http://localhost:65271
CHATWOOT_API_TOKEN=<api_access_token_de_um_agente>
CHATWOOT_WEBHOOK_SECRET=<secret_do_webhook_chatwoot>
OLLAMA_BASE_URL=http://127.0.0.1:11434
RAG_OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3
OLLAMA_FALLBACK_MODEL=phi3:medium
OLLAMA_SYSTEM_PROMPT=Voce e um atendente virtual objetivo, educado e breve. Responda sempre em portugues do Brasil, sem inventar informacoes e encaminhe para um humano quando nao tiver certeza.
OLLAMA_TIMEOUT_MAX_SECONDS=300
OLLAMA_MAIN_TIMEOUT=90
OLLAMA_FALLBACK_TIMEOUT=60
OLLAMA_KEEP_ALIVE=50m
OLLAMA_NUM_GPU=999
OLLAMA_NUM_CTX=16384
MAX_RESPONSE_CHARS=1200
IGNORE_BOT_PREFIX=!botoff

# Histórico de conversa
CHAT_HISTORY_ENABLED=true
CHAT_HISTORY_MAX_MESSAGES=10
CHAT_HISTORY_MAX_CHARS=3000
CHAT_HISTORY_INCLUDE_AGENT=true
CHAT_HISTORY_REQUEST_TIMEOUT=15

# Integração Shopify
# SHOPIFY_MODE aceita dois valores:
#   mock  — dados locais de teste (padrão, sem dependências externas)
#   mcp   — Shopify Storefront MCP Server em tempo real
SHOPIFY_MODE=mock
SHOPIFY_STORE_NAME=Nome da Loja
SHOPIFY_CURRENCY=BRL
SHOPIFY_MOCK_DELAY_MS=0

# Configuração do Shopify Storefront MCP Server (necessário quando SHOPIFY_MODE=mcp)
# Referência: https://shopify.dev/docs/apps/build/storefront-mcp/servers/storefront
# O Storefront MCP Server normalmente não requer autenticação.
# Algumas lojas podem restringir acesso no ambiente delas.
# Use o endpoint específico da sua loja:
SHOPIFY_MCP_ENDPOINT=https://<sua-loja>.myshopify.com/api/mcp
SHOPIFY_MCP_TIMEOUT=30

# Customer Account MCP (consultas autenticadas de pedido/conta)
# Descoberta automática no well-known:
#   https://<sua-loja>.myshopify.com/.well-known/customer-account-api
# O mcp_api retornado deve ser usado no endpoint abaixo.
# Este endpoint exige autenticação (Bearer token OAuth2/PKCE).
SHOPIFY_CUSTOMER_MCP_ENDPOINT=https://shopify.com/<shop_id>/account/customer/api/mcp
SHOPIFY_CUSTOMER_MCP_TOKEN=
SHOPIFY_CUSTOMER_MCP_TIMEOUT=30

# OAuth para Customer Account MCP (opcional: usa refresh_token para obter access_token automaticamente)
# Endpoints podem ser descobertos em:
#   https://<sua-loja>.myshopify.com/.well-known/openid-configuration
#   https://<sua-loja>.myshopify.com/.well-known/customer-account-api
SHOPIFY_CUSTOMER_OAUTH_TOKEN_ENDPOINT=https://shopify.com/authentication/<shop_id>/oauth/token
SHOPIFY_CUSTOMER_CLIENT_ID=
SHOPIFY_CUSTOMER_CLIENT_SECRET=
SHOPIFY_CUSTOMER_REFRESH_TOKEN=
SHOPIFY_CUSTOMER_SCOPES=openid email customer-account-api:full customer-account-mcp-api:full

# RAG de documentos
RAG_ENABLED=true
RAG_DOCS_PATH=./docs
RAG_VECTOR_DB_PATH=G:/whatsapp-integration/vectorstore
RAG_TOP_K=4
RAG_MAX_CONTEXT_CHARS=2500
RAG_EMBED_MODEL=nomic-embed-text
RAG_OLLAMA_REQUEST_TIMEOUT=90
RAG_OLLAMA_KEEP_ALIVE=50m
RAG_OLLAMA_NUM_GPU=999
RAG_CHUNK_SIZE=600
RAG_CHUNK_OVERLAP=150

# Query Planner (LLM analisa a mensagem e decide onde buscar contexto)
QUERY_PLANNER_ENABLED=true
QUERY_PLANNER_MODEL=
QUERY_PLANNER_TIMEOUT=30
